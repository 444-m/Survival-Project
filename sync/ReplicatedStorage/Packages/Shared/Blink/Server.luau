			if Events.Reliable[2] ~= nil then
				SerdesEvent = "TraceDash"
				Events.Reliable[2](Player, Value)
			else
				if #Queue.Reliable[2] > 256 then
					warn("[Blink]: Event queue of \"TraceDash\" exceeded 256, did you forget to implement a listener?")
				end
				table.insert(Queue.Reliable[2], {Player, Value} :: {any})
			end
		elseif Index == 16 then
			local Value: { Name: string, Action: string, Value: number } = ReadEVENT_GunCommand()
			if Events.Reliable[16] ~= nil then
				SerdesEvent = "GunCommand"
				Events.Reliable[16](Player, Value)
			else
				if #Queue.Reliable[16] > 256 then
					warn("[Blink]: Event queue of \"GunCommand\" exceeded 256, did you forget to implement a listener?")
				end
				table.insert(Queue.Reliable[16], {Player, Value} :: {any})
			end
		end
	end
end)
Unreliable.OnServerEvent:Connect(function(Player: Player, Buffer: buffer, Instances: {Instance})
	RecieveCursor = 0
	RecieveBuffer = Buffer
	RecieveInstances = Instances
	RecieveInstanceCursor = 0
	local Size = buffer.len(RecieveBuffer)
	if SerdesThread and coroutine.status(SerdesThread) == "suspended" then
		warn(`[Blink]: Yielded in a Sync call. Event "{SerdesEvent}" uses a Sync call, consider using an Async call instead.`)
		coroutine.close(SerdesThread)
	end
	SerdesThread = coroutine.running()
	while (RecieveCursor < Size) do
		-- Read BLOCK: 1 bytes
		local BLOCK_START = Read(1)
		local Index = buffer.readu8(RecieveBuffer, BLOCK_START + 0)
		if Index == 0 then
			local Value: { Root: CFrame, Neck: CFrame, RShoulder: CFrame, LShoulder: CFrame, RHip: CFrame, LHip: CFrame } = ReadEVENT_JointReplicator()
			if Events.Unreliable[0] ~= nil then
				SerdesEvent = "JointReplicator"
				Events.Unreliable[0](Player, Value)
			end
		elseif Index == 1 then
			local Value: { SoundId: string, X: number, Y: number, Z: number, Volume: number?, Pitch: number?, MaxDistance: number?, EmitterSize: number?, StopAfter: number? } = ReadEVENT_SoundReplicator()
			if Events.Unreliable[1] ~= nil then
				SerdesEvent = "SoundReplicator"
				Events.Unreliable[1](Player, Value)
			end
		elseif Index == 2 then
			local Value: { UserId: number, Pitch: number, Yaw: number } = ReadEVENT_LookAngles()
			if Events.Unreliable[2] ~= nil then
				SerdesEvent = "LookAngles"
				Events.Unreliable[2](Player, Value)
			end
		end
	end
end)


